# ShadowFile environment
# Copy to .env.local for local dev; set real values in Vercel dashboard for prod.

# Anthropic API key. Used only by the Edge Function proxy at /api/chat.
# This key never reaches the browser.
ANTHROPIC_API_KEY=

# Optional: allow-list of origins for the proxy (comma-separated). Empty = same-origin only.
ALLOWED_ORIGINS=

# Optional: per-IP rate-limit window (requests per minute). Default 20.
RATE_LIMIT_RPM=20
