# ShadowFile environment
# Copy this file to .env.local, then fill in ONE of the two AI backend options below.

# ── OPTION A: Local Ollama (no API key, no rate limits, fully offline) ───────
# 1. Install Ollama: https://ollama.com
# 2. Run: ollama pull llama3.2
# 3. Run: ollama serve   (starts at http://localhost:11434)
# Then set:
OLLAMA_BASE_URL=
# OLLAMA_MODEL=llama3.1:8b   # default. Use llama3.2 for low-RAM machines, llama3.3:70b for best quality

# ── OPTION B: OpenRouter cloud (free tier, requires account) ─────────────────
# Sign up free at https://openrouter.ai → Keys → Create key (no credit card)
OPENROUTER_API_KEY=

# Optional: override the cloud model order (comma-separated OpenRouter model IDs)
# OPENROUTER_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemma-3-27b-it:free

# Optional: per-IP rate-limit (requests per minute). Default 20.
RATE_LIMIT_RPM=20
