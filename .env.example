# ShadowFile environment
# The start.sh / start.bat scripts write .env.local automatically.
# Only edit this manually if you are not using those scripts.

# ── AI backend priority ───────────────────────────────────────────────────────
# 1. If OLLAMA_BASE_URL is set → use local Ollama (no API key, no limits)
# 2. Else if OPENROUTER_API_KEY is set → use OpenRouter cloud
# 3. Else → show "run locally" message

# LOCAL AI (recommended) ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1

# Default: llama3.2 (~2 GB, fast setup)
# Stronger: llama3.1:8b (~5 GB, better instruction following)
# Run:  bash start.sh --strong   to switch automatically
OLLAMA_MODEL=llama3.2

# CLOUD AI (optional fallback) ────────────────────────────────────────────────
# Sign up free at https://openrouter.ai — no credit card required
OPENROUTER_API_KEY=

# Optional: override model order (comma-separated OpenRouter model IDs)
# OPENROUTER_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemma-3-27b-it:free

# Optional: per-IP rate-limit for cloud proxy (requests per minute)
RATE_LIMIT_RPM=20
